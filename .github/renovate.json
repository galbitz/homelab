{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "github>galbitz/homelab//.github/renovate/customManagers.json5"
  ],
  "ignorePaths": [
    "**/*.sops.*",
    "**/.archive/**",
    "**/resources/**"
  ],
  "mise": {
    "enabled": true
  },
  "docker-compose": {
    "managerFilePatterns": [
      "/(^|/)ansible/.+compose\\.ya?ml(?:\\.j2)?$/"
    ]
  },
  "packageRules": [
    {
      "matchPackageNames": ["louislam/uptime-kuma"],
      "sourceUrl": "https://github.com/louislam/uptime-kuma"
    },
    {
      "matchPackageNames": ["portainer/portainer-ce"],
      "sourceUrl": "https://github.com/portainer/portainer"
    },
    {
      "matchPackageNames": ["docker.io/traefik", "traefik"],
      "sourceUrl": "https://github.com/traefik/traefik"
    }
  ]
}
