---
# yaml-language-server: $schema=https://raw.githubusercontent.com/compose-spec/compose-spec/master/schema/compose-spec.json
networks:
  proxy:
    external: true
services:
  traefik:
    image: docker.io/traefik:v3.7.0
    container_name: traefik
    ports:
      - 80:80
      - 443:443
      - 8180:8080
    volumes:
      - ./config:/etc/traefik
      - /var/run/docker.sock:/var/run/docker.sock:ro
      - /etc/timezone:/etc/timezone:ro
      - /etc/localtime:/etc/localtime:ro
    environment:
      - CF_DNS_API_TOKEN={{ containers_traefik_cloudflare_dns_token }}
    networks:
      - proxy
    healthcheck:
      test: ["CMD", "traefik", "healthcheck", "--ping"]
      interval: 10s
      timeout: 5s
      retries: 3
      start_period: 10s
    restart: always
    labels:
      - "traefik.enable=true"
      - "traefik.docker.network=proxy"
      - "traefik.http.services.traefik.loadbalancer.server.port=8080"
      - "traefik.http.services.traefik.loadbalancer.server.scheme=http"
      - "traefik.http.routers.traefik-http.entrypoints=web"
      - "traefik.http.routers.traefik-http.rule=Host(`traefik.{{ containers_traefik_main_domain }}`) || Host(`traefik.{{ containers_traefik_secondary_domain }}`)"
      - "traefik.http.routers.traefik-https.entrypoints=websecure"
      - "traefik.http.routers.traefik-https.rule=Host(`traefik.{{ containers_traefik_main_domain }}`) || Host(`traefik.{{ containers_traefik_secondary_domain }}`)"
      - "traefik.http.routers.traefik-https.tls=true"
      - "traefik.http.routers.traefik-https.tls.certresolver=production"
      - "traefik.http.routers.traefik-https.tls.domains[0].main=*.{{ containers_traefik_main_domain }}"
      - "traefik.http.routers.traefik-https.tls.domains[0].sans=*.{{ containers_traefik_secondary_domain }}"
