---
networks:
  proxy:
    external: true
services:
  app:
    container_name: portainer
    image: portainer/portainer-ce:2.40.0
    volumes:
      - "{{ containers_portainer_dir }}/data:/data"
      - /var/run/docker.sock:/var/run/docker.sock
    restart: always
    networks:
      - proxy
    labels:
      - "traefik.enable=true"
      - "traefik.docker.network=proxy"
      - "traefik.http.services.portainer.loadbalancer.server.port=9000"
      - "traefik.http.services.portainer.loadbalancer.server.scheme=http"
      - "traefik.http.routers.portainer-http.entrypoints=web"
      - "traefik.http.routers.portainer-https.entrypoints=websecure"
      - "traefik.http.routers.portainer-https.tls=true"
      - "traefik.http.routers.portainer-http.rule=Host(`portainer.{{ containers_traefik_main_domain }}`) || Host(`portainer.{{ containers_traefik_secondary_domain }}`)"
      - "traefik.http.routers.portainer-https.rule=Host(`portainer.{{ containers_traefik_main_domain }}`) || Host(`portainer.{{ containers_traefik_secondary_domain }}`)"
      - "traefik.http.routers.portainer-https.tls.certresolver=production"
      - "traefik.http.routers.portainer-https.tls.domains[0].main=*.{{ containers_traefik_main_domain }}"
      - "traefik.http.routers.portainer-https.tls.domains[0].sans=*.{{ containers_traefik_secondary_domain }}" 
