networks:
  proxy:
    external: true
services:
  jellyfin:
    container_name: jellyfin
    image: jellyfin/jellyfin:10.11.8
    user: "{{ containers_jellyfin_uid }}:{{ containers_jellyfin_gid }}"
    cap_drop:
      - ALL
    security_opt:
      - no-new-privileges:true
    volumes:
      - "{{ containers_jellyfin_config_dir }}:/config"
      - "{{ containers_jellyfin_cache_dir }}:/cache"
      # TODO: Extract to variable
      - /mnt/music:/music:ro
      - /mnt/movies:/movies:ro
    restart: always
    networks:
      - proxy
    labels:
      - "traefik.enable=true"
      - "traefik.docker.network=proxy"
      - "traefik.http.services.jellyfin.loadbalancer.server.port=8096"
      - "traefik.http.services.jellyfin.loadbalancer.server.scheme=http"
      - "traefik.http.routers.jellyfin-http.entrypoints=web"
      - "traefik.http.routers.jellyfin-http.rule=HostRegexp(`^jellyfin\\..+`) || HostRegexp(`^media\\..+`)"
      - "traefik.http.routers.jellyfin-https.entrypoints=websecure"
      - "traefik.http.routers.jellyfin-https.rule=HostRegexp(`^jellyfin\\..+`) || HostRegexp(`^media\\..+`)"
#      - "traefik.http.routers.jellyfin-http.rule=Host(`jellyfin.{{ containers_traefik_main_domain }}`) || Host(`jellyfin.{{ containers_traefik_secondary_domain }}`) || Host(`media.{{ containers_traefik_main_domain }}`) || Host(`media.{{ containers_traefik_secondary_domain }}`)"
#      - "traefik.http.routers.jellyfin-https.entrypoints=websecure"
#      - "traefik.http.routers.jellyfin-https.rule=Host(`jellyfin.{{ containers_traefik_main_domain }}`) || Host(`jellyfin.{{ containers_traefik_secondary_domain }}`) || Host(`media.{{ containers_traefik_main_domain }}`) || Host(`media.{{ containers_traefik_secondary_domain }}`)"
      - "traefik.http.routers.jellyfin-https.tls=true"
      - "traefik.http.routers.jellyfin-https.tls.certresolver=production"
      - "traefik.http.routers.jellyfin-https.tls.domains[0].main=*.{{ containers_traefik_main_domain }}"
      - "traefik.http.routers.jellyfin-https.tls.domains[0].sans=*.{{ containers_traefik_secondary_domain }}"